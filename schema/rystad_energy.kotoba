// Rystad_energy clean-room schema -> Datomic EAVT mapping
// Generated by deepen_actors.py (ADR 260607 deepening phase).

namespace rystad_energy {

    entity Commodity {
        id: string @unique
        symbol: string
        name: string
        unit: string
        exchange: string
        createdAt: datetime
        updatedAt: datetime
    }

    entity Price {
        id: string @unique
        commodityId: string
        value: float
        currency: string
        asOf: datetime
        createdAt: datetime
        updatedAt: datetime
    }

    entity Contract {
        id: string @unique
        commodityId: string
        expiry: string
        lastPrice: float
        createdAt: datetime
        updatedAt: datetime
    }

    entity Series {
        id: string @unique
        commodityId: string
        frequency: string
        source: string
        createdAt: datetime
        updatedAt: datetime
    }

    entity Inventory {
        id: string @unique
        commodityId: string
        region: string
        quantity: float
        reportedAt: datetime
        createdAt: datetime
        updatedAt: datetime
    }

    entity Forecast {
        id: string @unique
        commodityId: string
        period: string
        value: float
        createdAt: datetime
        updatedAt: datetime
    }

}

    // Auto-injected Cognitive Schema
    entity CognitiveRecord {
        id: string @unique
        originalPayload: string
        aiStatus: string
        aiInsights: json
        computedAt: datetime
    }
